# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Google Service Account Credentials
# Create a Service Account at https://console.cloud.google.com/iam-admin/serviceaccounts
# Share your spreadsheet with the Service Account email.
GOOGLE_SERVICE_ACCOUNT_EMAIL="your-service-account@project.iam.gserviceaccount.com"
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# The ID of the Google Spreadsheet to log data to
GOOGLE_SPREADSHEET_ID="your-spreadsheet-id"

# The ID of the Google Drive folder to store images
GOOGLE_DRIVE_PARENT_FOLDER_ID="your-drive-folder-id"

# Session Secret for cookie-session
SESSION_SECRET="aqua-scan-secret-change-me"

# Simple Access Key for app restriction
ACCESS_KEY="my-secret-access-key"

# PUBLIC_URL: Set this to your "Shared App URL" to make spreadsheet links public
PUBLIC_URL="https://ais-pre-..."
